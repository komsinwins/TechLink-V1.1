rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net (default deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow public access to customers
    match /customers/{customerId} {
      allow read, write: if true;
    }

    // Allow public access to onsiteJobs
    match /onsiteJobs/{jobId} {
      allow read, write: if true;
    }

    // Allow public access to oncallJobs
    match /oncallJobs/{jobId} {
      allow read, write: if true;
    }

    // Allow public access to claims
    match /claims/{claimId} {
      allow read, write: if true;
    }

    // Allow public access to settings
    match /settings/{settingId} {
      allow read, write: if true;
    }
  }
}
